# Server
PORT=5000

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=cv_matching_db
PG_USER=postgres
PG_PASSWORD=your_password

# MongoDB
MONGO_URI=mongodb://localhost:27017/cv_matching

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
